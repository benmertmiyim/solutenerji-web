---
import { siteConfig } from '../../site.config';
import { getFormspreeAction } from '../../lib/formspree';

const formAction = getFormspreeAction();
---
<section id="iletisim" data-scroll-section class="section-anchor">
  <section class="relative flex min-h-[320px] items-center overflow-hidden bg-primary pb-0 pt-20">
    <div class="absolute inset-0 z-0 opacity-20">
      <img
        class="h-full w-full object-cover"
        alt="Mühendislik ve enerji projeleri üzerinde çalışan ekip"
        src="/assets/contact-hero.jpg"
        width="1920"
        height="640"
      />
    </div>
    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-20">
      <span class="mb-4 block text-xs font-bold uppercase tracking-[0.2em] text-secondary-container">
        Bizimle İletişime Geçin
      </span>
      <h2 class="mb-4 font-headline text-3xl font-extrabold leading-tight tracking-tighter text-white md:text-4xl lg:text-6xl">
        Projenizi Birlikte <br /><span class="text-secondary-container">Hayata Geçirelim</span>
      </h2>
      <p class="max-w-xl text-lg leading-relaxed text-primary-fixed-dim">
        Güneş enerjisi, EV şarj veya danışmanlık konularında uzman ekibimiz size en uygun çözümü sunmak için hazır.
      </p>
    </div>
  </section>

  <section class="bg-surface-container-low px-6 py-20">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-start gap-16 md:grid-cols-2">
      <div>
        <span class="mb-4 block text-sm font-bold uppercase tracking-widest text-secondary">
          İletişim Kanalları
        </span>
        <h3 class="mb-8 font-headline text-3xl font-bold tracking-tight text-primary">
          Size nasıl yardımcı olabiliriz?
        </h3>

        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary">
              <span class="material-symbols-outlined text-secondary-container">location_on</span>
            </div>
            <div>
              <div class="mb-1 text-xs font-bold uppercase tracking-widest text-secondary">Adres</div>
              <div class="font-semibold text-on-surface">{siteConfig.address}</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary">
              <span class="material-symbols-outlined text-secondary-container">mail</span>
            </div>
            <div>
              <div class="mb-1 text-xs font-bold uppercase tracking-widest text-secondary">E-Posta</div>
              <a
                href={`mailto:${siteConfig.email}`}
                class="font-semibold text-primary transition-colors hover:text-secondary"
              >
                {siteConfig.email}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary">
              <span class="material-symbols-outlined text-secondary-container">schedule</span>
            </div>
            <div>
              <div class="mb-1 text-xs font-bold uppercase tracking-widest text-secondary">Çalışma Saatleri</div>
              <div class="font-semibold text-on-surface">Pazartesi – Cumartesi: 09:00 – 18:00</div>
              <div class="mt-1 text-sm text-on-surface-variant">Acil teknik destek için 7/24 ulaşabilirsiniz.</div>
            </div>
          </div>
        </div>

        <div class="mt-12 rounded-xl bg-surface-container-lowest p-8">
          <h4 class="mb-4 font-headline text-lg font-bold text-primary">Neden Solut Enerji?</h4>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-on-surface-variant">
              <span class="material-symbols-outlined text-base text-secondary-container" style="font-variation-settings: 'FILL' 1;">
                check_circle
              </span>
              Ege bölgesinde geniş hizmet ağı
            </li>
            <li class="flex items-center gap-3 text-sm text-on-surface-variant">
              <span class="material-symbols-outlined text-base text-secondary-container" style="font-variation-settings: 'FILL' 1;">
                check_circle
              </span>
              İhtiyaca özel enerji sistemleri mühendisliği çözümleri
            </li>
            <li class="flex items-center gap-3 text-sm text-on-surface-variant">
              <span class="material-symbols-outlined text-base text-secondary-container" style="font-variation-settings: 'FILL' 1;">
                check_circle
              </span>
              Kurulum öncesi ve sonrası 7/24 teknik destek
            </li>
            <li class="flex items-center gap-3 text-sm text-on-surface-variant">
              <span class="material-symbols-outlined text-base text-secondary-container" style="font-variation-settings: 'FILL' 1;">
                check_circle
              </span>
              Uluslararası standartlara uygun ürün ve kurulum hizmetleri
            </li>
          </ul>
        </div>
      </div>

      <div class="rounded-xl bg-surface-container-lowest p-10 shadow-sm">
        <h4 class="mb-2 font-headline text-2xl font-bold text-primary">Ücretsiz Teklif Alın</h4>
        <p class="mb-8 text-sm text-on-surface-variant">Formu doldurun, en kısa sürede size dönelim.</p>

        {!formAction && (
          <div
            role="alert"
            class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950"
          >
            İletişim formu henüz yapılandırılmadı. Canlı ortamda <code class="rounded bg-amber-100 px-1">PUBLIC_FORMSPREE_FORM_ID</code> ortam değişkenini ayarlayın.
          </div>
        )}

        <form
          data-contact-form
          action={formAction ?? undefined}
          method="POST"
          class="space-y-6"
          novalidate
        >
          <input type="hidden" name="_subject" value="Solut Enerji - Yeni İletişim Talebi" />
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="space-y-2">
              <label class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant" for="contact-ad">
                Ad Soyad *
              </label>
              <input
                id="contact-ad"
                name="ad_soyad"
                type="text"
                required
                placeholder="Ad Soyad"
                class="placeholder-outline w-full rounded-sm border-0 border-b border-outline-variant bg-transparent py-3 text-sm text-on-surface transition-colors focus:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-container-lowest"
              />
            </div>
            <div class="space-y-2">
              <label class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant" for="contact-tel">
                Telefon
              </label>
              <input
                id="contact-tel"
                name="telefon"
                type="tel"
                placeholder="+90 5xx xxx xx xx"
                class="placeholder-outline w-full rounded-sm border-0 border-b border-outline-variant bg-transparent py-3 text-sm text-on-surface transition-colors focus:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-container-lowest"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant" for="contact-email">
              E-Posta Adresi *
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              placeholder="email@adresiniz.com"
              class="placeholder-outline w-full rounded-sm border-0 border-b border-outline-variant bg-transparent py-3 text-sm text-on-surface transition-colors focus:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-container-lowest"
            />
          </div>

          <div class="space-y-2">
            <label class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant" for="contact-hizmet">
              Hizmet Türü
            </label>
            <select
              id="contact-hizmet"
              name="hizmet_turu"
              data-service-select
              class="w-full rounded-sm border-0 border-b border-outline-variant bg-transparent py-3 text-sm text-on-surface transition-colors focus:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-container-lowest"
            >
              <option value="">Seçiniz...</option>
              <option value="mesken_ges">Mesken Çatı GES Kurulumu</option>
              <option value="ev_sarj">EV Şarj İstasyonu</option>
              <option value="ges_danismanlik">GES Danışmanlık</option>
              <option value="diger">Diğer</option>
            </select>
          </div>

          <div class="space-y-2">
            <label class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant" for="contact-mesaj">
              Mesajınız *
            </label>
            <textarea
              id="contact-mesaj"
              name="mesaj"
              required
              rows="4"
              placeholder="Projeniz hakkında kısaca bilgi verin..."
              class="placeholder-outline w-full resize-none rounded-sm border-0 border-b border-outline-variant bg-transparent py-3 text-sm text-on-surface transition-colors focus:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-container-lowest"
            ></textarea>
          </div>

          <div
            id="contact-form-error"
            role="alert"
            hidden
            class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950"
          />

          <div class="pt-2">
            <button
              id="contact-submit-btn"
              type="submit"
              disabled={!formAction}
              class="flex w-full items-center justify-center gap-2 rounded-md bg-secondary-container py-4 font-headline font-extrabold text-on-secondary-fixed transition-all hover:opacity-90 active:scale-95 disabled:cursor-not-allowed disabled:opacity-50"
            >
              <span id="contact-submit-label">Mesajı Gönder</span>
              <span class="material-symbols-outlined" aria-hidden="true">send</span>
            </button>
          </div>
          <p class="text-center text-[11px] text-on-surface-variant">
            Gönder butonuna basarak{' '}
            <a href="/gizlilik-politikasi" class="underline hover:text-primary">Gizlilik Politikamızı</a> kabul etmiş olursunuz.
          </p>
        </form>
      </div>
    </div>
  </section>
</section>

<script is:inline>
  (function () {
    const form = document.querySelector('[data-contact-form]');
    if (!(form instanceof HTMLFormElement) || !form.action) return;

    const btn = document.getElementById('contact-submit-btn');
    const label = document.getElementById('contact-submit-label');
    const errBox = document.getElementById('contact-form-error');
    const thanksPath = '/tesekkurler/';

    function hideError() {
      if (errBox) {
        errBox.textContent = '';
        errBox.hidden = true;
      }
    }

    function showError(msg) {
      if (errBox) {
        errBox.textContent = msg;
        errBox.hidden = false;
      }
    }

    function setBusy(busy) {
      if (btn instanceof HTMLButtonElement) {
        btn.disabled = busy;
        btn.setAttribute('aria-busy', busy ? 'true' : 'false');
      }
      if (label) label.textContent = busy ? 'Gönderiliyor…' : 'Mesajı Gönder';
    }

    function wireField(id, emptyMsg, typeMismatchMsg) {
      const el = document.getElementById(id);
      if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement)) return;
      el.addEventListener('input', function () {
        el.setCustomValidity('');
      });
      el.addEventListener('invalid', function () {
        if (el.validity.valueMissing) el.setCustomValidity(emptyMsg);
        else if (el.type === 'email' && el.validity.typeMismatch && typeMismatchMsg)
          el.setCustomValidity(typeMismatchMsg);
        else el.setCustomValidity('');
      });
    }

    wireField('contact-ad', 'Lütfen ad ve soyadınızı girin.');
    wireField('contact-email', 'Lütfen e-posta adresinizi girin.', 'Lütfen geçerli bir e-posta adresi girin.');
    wireField('contact-mesaj', 'Lütfen mesajınızı yazın.');

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      hideError();
      if (!form.reportValidity()) return;

      setBusy(true);

      var fd = new FormData(form);
      fetch(form.action, {
        method: 'POST',
        body: fd,
        headers: { Accept: 'application/json' },
      })
        .then(function (res) {
          return res.text().then(function (text) {
            var data = {};
            if (text) {
              try {
                data = JSON.parse(text);
              } catch (_) {}
            }
            return { res: res, data: data };
          });
        })
        .then(function (_ref) {
          var res = _ref.res;
          var data = _ref.data;
          if (res.ok) {
            window.location.assign(new URL(thanksPath, window.location.origin).href);
            return;
          }
          var msg =
            (data && (data.error || data.message)) ||
            (res.status === 429
              ? 'Çok fazla deneme yapıldı. Lütfen bir süre sonra tekrar deneyin.'
              : 'Gönderim tamamlanamadı. Lütfen alanları kontrol edip yeniden deneyin.');
          showError(typeof msg === 'string' ? msg : 'Gönderim tamamlanamadı.');
          setBusy(false);
        })
        .catch(function () {
          showError('Bağlantı hatası. İnternetinizi kontrol edip tekrar deneyin.');
          setBusy(false);
        });
    });
  })();
</script>
