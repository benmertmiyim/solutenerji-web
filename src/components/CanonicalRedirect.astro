---
/**
 * Eski URL’ler için: kanonik hedef + noindex + anında yönlendirme.
 * Netlify _redirects 301 ile birlikte kullanılır; statik host yedekleri için.
 */
interface Props {
  canonicalPath: string;
  description: string;
  title: string;
}

const { canonicalPath, description, title } = Astro.props;
const site = Astro.site ?? new URL('https://solutenerji.com');
const canonical = new URL(canonicalPath.replace(/^\//, ''), site).href;
const target = canonical;
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex,follow" />
  <link rel="canonical" href={canonical} />
  <meta http-equiv="refresh" content={`0;url=${target}`} />
</head>
<body>
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
  <p>
    Yönlendiriliyorsunuz.
    <a href={target}>Devam etmek için tıklayın.</a>
  </p>
</body>
</html>
