---
const navLinks = [
  { href: '/#ana-sayfa', label: 'Ana Sayfa', anchor: true },
  { href: '/#gunes-enerjisi', label: 'Güneş Enerjisi', anchor: true },
  { href: '/#ev-sarj-ve-danismanlik', label: 'EV Şarj', anchor: true },
  { href: '/#danismanlik', label: 'Danışmanlık', anchor: true },
  { href: '/#iletisim', label: 'İletişim', anchor: true },
] as const;
---
<nav
  class="fixed top-0 z-50 w-full border-b border-slate-100 bg-white shadow-sm max-md:backdrop-blur-none md:bg-white/80 md:backdrop-blur-md"
>
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
    <a
      href="/#ana-sayfa"
      aria-label="Solut Enerji"
      class="relative z-[2] flex min-w-0 max-w-[65%] items-center [isolation:isolate] sm:max-w-none"
    >
      <!-- Açık nav zemini: her zaman renkli logo.svg. logo.png footer’da invert ile beyaz; mobil nav’da PNG beyaz zeminde kaybolur. -->
      <img
        alt="Solut Enerji Logo"
        width="612"
        height="408"
        decoding="sync"
        fetchpriority="high"
        class="h-12 w-auto max-h-12 origin-left [-webkit-backface-visibility:hidden] [backface-visibility:hidden] [transform:translateZ(0)] sm:h-14 sm:max-h-14 md:h-16 md:max-h-none md:w-auto md:[transform:translate3d(0,0,0)_scale(1.5)]"
        src="/assets/logo.svg"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center font-body text-sm font-semibold tracking-tight md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          {...(link.anchor
            ? { 'data-anchor-link': true, 'data-active': 'false' }
            : {})}
          class="mx-4 border-b-2 border-transparent pb-1 text-slate-600 transition-colors hover:text-primary"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="relative z-10 flex shrink-0 items-center gap-3">
      <a
        href="/#iletisim"
        data-service="diger"
        class="hidden rounded-md bg-primary px-6 py-2.5 text-sm font-semibold text-on-primary transition-all hover:opacity-80 active:scale-95 sm:inline-block"
      >
        Teklif Al
      </a>

      <button
        id="mobile-menu-btn"
        type="button"
        aria-controls="mobile-menu"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-label="Menüyü aç"
        class="relative inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg text-slate-700 transition-colors hover:bg-slate-100 md:hidden"
      >
        <span
          class="material-symbols-outlined pointer-events-none absolute left-1/2 top-1/2 block -translate-x-1/2 -translate-y-1/2 text-2xl leading-none"
          style="font-size: 1.5rem; width: 1.5rem; height: 1.5rem;"
          aria-hidden="true"
        >
          menu
        </span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-slate-100 bg-white md:hidden"
    role="dialog"
    aria-modal="false"
    aria-label="Mobil menü"
  >
    <div class="mobile-menu-panel mx-auto max-w-7xl space-y-1 px-6 pb-6 pt-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-mobile-link
          class="block rounded-lg px-4 py-3 font-body text-base font-semibold text-slate-700 transition-colors hover:bg-primary/5 hover:text-primary"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3">
        <a
          href="/#iletisim"
          data-service="diger"
          data-mobile-link
          class="block w-full rounded-md bg-primary py-3 text-center text-sm font-semibold text-on-primary transition-all hover:opacity-80 active:scale-95"
        >
          Teklif Al
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuPanel = mobileMenu?.querySelector('.mobile-menu-panel');

    if (!menuBtn || !mobileMenu || !menuPanel) return;

    function getFocusable() {
      return Array.from(
        menuPanel.querySelectorAll('a[href], button:not([disabled])'),
      ).filter(function (el) {
        return el instanceof HTMLElement && el.offsetParent !== null;
      });
    }

    function setOpen(open) {
      if (open) {
        mobileMenu.classList.remove('hidden');
        menuBtn.setAttribute('aria-expanded', 'true');
        menuBtn.setAttribute('aria-label', 'Menüyü kapat');
        mobileMenu.setAttribute('aria-modal', 'true');
        document.body.style.overflow = 'hidden';
        const focusable = getFocusable();
        if (focusable[0] instanceof HTMLElement) focusable[0].focus();
      } else {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.setAttribute('aria-label', 'Menüyü aç');
        mobileMenu.setAttribute('aria-modal', 'false');
        document.body.style.overflow = '';
        menuBtn.focus();
      }
    }

    function isOpen() {
      return !mobileMenu.classList.contains('hidden');
    }

    function onDocumentKeydown(e) {
      if (!isOpen()) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        setOpen(false);
        document.removeEventListener('keydown', onDocumentKeydown);
        return;
      }
      if (e.key !== 'Tab') return;
      const focusable = getFocusable();
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      const active = document.activeElement;
      if (e.shiftKey) {
        if (active === first) {
          e.preventDefault();
          last.focus();
        }
      } else if (active === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function onDocumentPointerDown(e) {
      if (!isOpen()) return;
      const t = e.target;
      if (!(t instanceof Node)) return;
      if (mobileMenu.contains(t) || menuBtn.contains(t)) return;
      setOpen(false);
      document.removeEventListener('pointerdown', onDocumentPointerDown, true);
      document.removeEventListener('keydown', onDocumentKeydown);
    }

    menuBtn.addEventListener('click', function () {
      if (isOpen()) {
        setOpen(false);
        document.removeEventListener('pointerdown', onDocumentPointerDown, true);
        document.removeEventListener('keydown', onDocumentKeydown);
      } else {
        setOpen(true);
        document.addEventListener('pointerdown', onDocumentPointerDown, true);
        document.addEventListener('keydown', onDocumentKeydown);
      }
    });

    document.querySelectorAll('[data-mobile-link]').forEach(function (link) {
      link.addEventListener('click', function () {
        setOpen(false);
        document.removeEventListener('pointerdown', onDocumentPointerDown, true);
        document.removeEventListener('keydown', onDocumentKeydown);
      });
    });
  })();
</script>
