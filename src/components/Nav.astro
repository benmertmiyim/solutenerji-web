---
const navLinks = [
  { href: '/#ana-sayfa', label: 'Ana Sayfa' },
  { href: '/#gunes-enerjisi', label: 'Güneş Enerjisi' },
  { href: '/#ev-sarj-ve-danismanlik', label: 'EV Şarj' },
  { href: '/#danismanlik', label: 'Danışmanlık' },
  { href: '/#iletisim', label: 'İletişim' },
];
---
<nav class="fixed top-0 z-50 w-full border-b border-slate-100 bg-white/80 shadow-sm backdrop-blur-md dark:border-slate-800 dark:bg-slate-950/80 dark:shadow-none">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
    <a href="/#ana-sayfa" aria-label="Solut Enerji" class="flex items-center">
      <img
        alt="Solut Enerji Logo"
        class="h-16 w-auto origin-left scale-[1.2] transform-gpu md:scale-[1.5]"
        src="/assets/logo.svg"
      >
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center font-body text-sm font-semibold tracking-tight md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-anchor-link
          data-active="false"
          class="mx-4 border-b-2 border-transparent pb-1 text-slate-600 transition-colors hover:text-blue-900 dark:text-slate-400 dark:hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a
        href="/#iletisim"
        data-service="diger"
        class="hidden rounded-md bg-primary px-6 py-2.5 text-sm font-semibold text-on-primary transition-all hover:opacity-80 active:scale-95 sm:inline-block"
      >
        Teklif Al
      </a>

      <!-- Hamburger Button -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Menüyü aç"
        aria-expanded="false"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-slate-700 transition-colors hover:bg-slate-100 md:hidden"
      >
        <span id="hamburger-icon" class="material-symbols-outlined text-2xl">menu</span>
        <span id="close-icon" class="material-symbols-outlined hidden text-2xl">close</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-100 bg-white/95 backdrop-blur-lg md:hidden"
  >
    <div class="mx-auto max-w-7xl space-y-1 px-6 pb-6 pt-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-mobile-link
          class="block rounded-lg px-4 py-3 font-body text-base font-semibold text-slate-700 transition-colors hover:bg-primary/5 hover:text-primary"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3">
        <a
          href="/#iletisim"
          data-service="diger"
          data-mobile-link
          class="block w-full rounded-md bg-primary py-3 text-center text-sm font-semibold text-on-primary transition-all hover:opacity-80 active:scale-95"
        >
          Teklif Al
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  if (menuBtn && mobileMenu && hamburgerIcon && closeIcon) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');

      if (isOpen) {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      } else {
        mobileMenu.classList.remove('hidden');
        hamburgerIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        menuBtn.setAttribute('aria-expanded', 'true');
      }
    });

    // Close menu when a link is clicked
    document.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
