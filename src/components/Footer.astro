---
import { siteConfig } from '../site.config';

const currentYear = new Date().getFullYear();
---
<footer class="bg-primary text-white">
  <!-- Main Footer Content -->
  <div class="mx-auto max-w-7xl px-6 py-12 lg:py-20">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4 lg:gap-12">

      <!-- Column 1: Brand & About -->
      <div class="lg:col-span-1">
        <a href="/#ana-sayfa" class="mb-6 inline-block">
          <!-- Küçük ekranda filtreli SVG yerine PNG; mavi footer arka planında invert ile beyaz logo -->
          <picture>
            <source media="(max-width: 767px)" srcset="/assets/logo.png" type="image/png" />
            <img
              alt="Solut Enerji Logo"
              width="612"
              height="408"
              decoding="async"
              class="h-16 w-auto max-h-16 brightness-0 invert [-webkit-backface-visibility:hidden] [backface-visibility:hidden] [transform:translateZ(0)]"
              src="/assets/logo.svg"
            />
          </picture>
        </a>
        <p class="mb-6 text-sm leading-relaxed text-slate-300 lg:mb-8">
          Yüksek mühendislik standartları ile güneşten gelen gücü yaşam alanlarınıza ve ulaşımınıza entegre ediyoruz.
        </p>
        <div class="flex gap-4">
          <a href={siteConfig.instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10 text-slate-300 transition-all hover:bg-secondary-container hover:text-primary">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={siteConfig.linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10 text-slate-300 transition-all hover:bg-secondary-container hover:text-primary">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={`mailto:${siteConfig.email}`} aria-label="E-posta" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10 text-slate-300 transition-all hover:bg-secondary-container hover:text-primary">
            <span class="material-symbols-outlined text-xl">mail</span>
          </a>
        </div>
      </div>

      <!-- Column 2: Çözümlerimiz -->
      <div class="hidden md:block">
        <h4 class="mb-6 font-headline text-sm font-bold uppercase tracking-[0.2em] text-secondary-container">
          Çözümlerimiz
        </h4>
        <ul class="space-y-3">
          <li>
            <a href="/hizmetler/mesken-cati-ges/" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              Güneş Enerjisi Sistemleri
            </a>
          </li>
          <li>
            <a href="/hizmetler/ev-sarj-istasyonu/" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              EV Şarj Altyapısı
            </a>
          </li>
          <li>
            <a href="/hizmetler/ges-danismanlik/" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              GES Danışmanlık
            </a>
          </li>
          <li>
            <a href="/hizmetler/mesken-cati-ges/" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              Enerji Depolama
            </a>
          </li>
          <li>
            <a href="/hizmetler/mesken-cati-ges/" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              Bakım ve Servis
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Kurumsal -->
      <div class="hidden lg:block">
        <h4 class="mb-6 font-headline text-sm font-bold uppercase tracking-[0.2em] text-secondary-container">
          Kurumsal
        </h4>
        <ul class="space-y-3">
          <li>
            <a href="/#ana-sayfa" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              Hakkımızda
            </a>
          </li>
          <li>
            <a href="/#ana-sayfa" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              Referanslarımız
            </a>
          </li>
          <li>
            <a href="/#ana-sayfa" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              Kariyer
            </a>
          </li>
          <li>
            <a href="/#iletisim" class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              İletişim
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: İletişim Bilgileri -->
      <div>
        <h4 class="mb-6 font-headline text-sm font-bold uppercase tracking-[0.2em] text-secondary-container">
          İletişim
        </h4>
        <ul class="space-y-3 lg:space-y-5">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined mt-0.5 text-lg text-secondary-container">location_on</span>
            <span class="text-sm leading-relaxed text-slate-300">
              {siteConfig.address}
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined mt-0.5 text-lg text-secondary-container">phone</span>
            <a href={`tel:${siteConfig.phoneE164.replace(/\s/g, '')}`} class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              {siteConfig.phoneDisplay}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined mt-0.5 text-lg text-secondary-container">mail</span>
            <a href={`mailto:${siteConfig.email}`} class="text-sm text-slate-300 transition-colors hover:text-secondary-container">
              {siteConfig.email}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined mt-0.5 text-lg text-secondary-container">schedule</span>
            <span class="text-sm leading-relaxed text-slate-300">
              Pazartesi – Cumartesi: 09:00 – 18:00
            </span>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 text-center md:flex-row md:text-left">
      <p class="text-xs tracking-wide text-slate-400">
        © {currentYear} {siteConfig.companyLegalName}. Tüm hakları saklıdır.
      </p>
      <div class="flex flex-wrap justify-center gap-6 text-xs tracking-wide">
        <a href="/gizlilik-politikasi" class="text-slate-400 transition-colors hover:text-secondary-container">Gizlilik Politikası</a>
        <a href="/cerez-politikasi" class="text-slate-400 transition-colors hover:text-secondary-container">Çerez Politikası</a>
        <a href="/kvkk-aydinlatma" class="text-slate-400 transition-colors hover:text-secondary-container">KVKK Aydınlatma Metni</a>
        <a href="/kullanim-kosullari" class="text-slate-400 transition-colors hover:text-secondary-container">Kullanım Koşulları</a>
      </div>
    </div>
  </div>
</footer>
