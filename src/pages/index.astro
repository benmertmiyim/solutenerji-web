---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import EvConsultingSection from '../components/sections/EvConsultingSection.astro';
import HomeHero from '../components/sections/HomeHero.astro';

import ServicesOverview from '../components/sections/ServicesOverview.astro';
import SolarSection from '../components/sections/SolarSection.astro';
import SinglePageBehavior from '../components/SinglePageBehavior.astro';
---
<BaseLayout
  title="Solut Enerji | İzmir ve Ege’de Mesken GES & EV Şarj"
  description="İzmir merkezli mühendislik ekibiyle Ege bölgesinde mesken çatı GES, elektrikli araç şarj altyapısı ve GES danışmanlığı. Anahtar teslim kurulum ve şeffaf süreç."
  keywords="solut enerji, izmir güneş enerjisi, ege çatı ges, ev şarj izmir, ges danışmanlık"
>
  <div id="ana-sayfa" data-scroll-section class="section-anchor">
    <HomeHero />
    <ServicesOverview />

  </div>
  <SolarSection />
  <EvConsultingSection />
  
  <ContactSection />
  <SinglePageBehavior />
</BaseLayout>
